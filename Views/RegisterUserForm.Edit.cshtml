@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using System.Linq

<style>

/* Фон страницы */
body {
    background: #0a0e27 !important;
}

.d-flex.align-items-center.justify-content-center.h-100 {
    background: #0a0e27 !important;
    display: block !important;
    height: auto !important;
}
/* Скрыть все элементы Layout на этих страницах */
.navbar { display: none !important; }
.footer { display: none !important; }

/* Убрать sticky позиционирование у Layout navbar если он всё равно показывается */
nav:not(.ss-navbar) { display: none !important; }
footer:not(.ss-footer) { display: none !important; }
/* Исправить позиционирование ss-navbar */
.d-flex.align-items-center.justify-content-center.h-100 {
    display: block !important;
    height: auto !important;
}

.ss-navbar {
    position: fixed !important;
    top: 0; left: 0; right: 0;
    width: 100%;
}

.ss-auth-page {
    margin-top: 80px;
}

.ss-footer {
    margin-top: 0;
}
.ss-footer {
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    width: 100vw;
}
    .ss-navbar {
        position: sticky; top: 0; z-index: 100;
        background: rgba(10,14,39,0.95); backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(0,242,254,0.15); padding: 18px 40px;
        font-family: 'Inter','Segoe UI',sans-serif;
    }
    .ss-navbar-inner { max-width:1400px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; }
    .ss-logo { display:flex; align-items:center; gap:10px; font-size:1.6rem; font-weight:800; text-decoration:none; color:white; letter-spacing:-0.5px; }
    .ss-logo-accent { color:#00f2fe; }
    .ss-nav-menu { display:flex; gap:30px; list-style:none; margin:0; padding:0; }
    .ss-nav-menu a { color:#cbd5e1; text-decoration:none; font-weight:500; padding:8px 18px; border-radius:10px; transition:all 0.2s; font-size:0.95rem; }
    .ss-nav-menu a:hover { background:rgba(0,242,254,0.1); color:#00f2fe; }
    .ss-nav-right { display:flex; align-items:center; gap:12px; }
    .ss-nav-cart { display:flex; align-items:center; gap:8px; padding:10px 18px; border:1px solid rgba(0,242,254,0.3); border-radius:12px; color:#00f2fe; text-decoration:none; font-weight:600; }
    .ss-nav-cart:hover { background:rgba(0,242,254,0.1); }
    .ss-cart-count { background:#00f2fe; color:#0a0e27; width:24px; height:24px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:0.8rem; font-weight:800; }

    .ss-auth-page { min-height:calc(100vh - 130px); display:flex; align-items:center; justify-content:center; padding:48px 20px; font-family:'Inter','Segoe UI',sans-serif; -webkit-font-smoothing:antialiased; }

    .auth-card { width:100%; max-width:480px; background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%); border:1px solid rgba(0,242,254,0.2); border-radius:24px; padding:48px 44px; box-shadow:0 25px 80px rgba(0,0,0,0.4); color:#fff; }
    .auth-logo { display:flex; align-items:center; justify-content:center; gap:8px; font-size:1.5rem; font-weight:800; color:white; text-decoration:none; margin-bottom:28px; }
    .auth-logo-accent { color:#00f2fe; }
    .auth-title { margin:0 0 8px; font-size:1.7rem; font-weight:800; letter-spacing:-0.5px; color:#fff; text-align:center; }
    .auth-subtitle { margin:0 0 28px; font-size:0.9rem; color:#64748b; text-align:center; }
    .form-horizontal { display:grid; gap:16px; }
    .mb-3 { margin-bottom:0 !important; }
    .form-label { display:block; margin-bottom:6px; font-size:0.83rem; font-weight:600; color:#94a3b8; }

    .form-control { width:100%; min-height:48px; padding:12px 16px; border-radius:12px; border:1px solid rgba(255,255,255,0.1); background:rgba(0,0,0,0.3); color:#fff; font-size:0.95rem; font-family:'Inter','Segoe UI',sans-serif; outline:none; transition:0.2s ease; box-sizing:border-box; }
    .form-control::placeholder { color:rgba(255,255,255,0.25); }
    .form-control:focus { border-color:rgba(0,242,254,0.5); box-shadow:0 0 0 3px rgba(0,242,254,0.1); background:rgba(0,0,0,0.4); color:#fff; outline:none; }
    input:-webkit-autofill, input:-webkit-autofill:hover, input:-webkit-autofill:focus { -webkit-text-fill-color:#ffffff !important; caret-color:#ffffff !important; transition:background-color 9999s ease-in-out 0s; box-shadow:0 0 0 1000px rgba(0,0,0,0.3) inset !important; }

    .btn.btn-primary { display:inline-flex; align-items:center; justify-content:center; width:100%; min-height:48px; padding:0 28px; border-radius:12px; font-size:1rem; font-weight:700; cursor:pointer; transition:0.2s ease; border:none; background:linear-gradient(135deg,#00f2fe 0%,#4facfe 100%); color:#0a0e27; font-family:'Inter','Segoe UI',sans-serif; box-shadow:0 8px 24px rgba(0,242,254,0.25); margin-top:8px; }
    .btn.btn-primary:hover { transform:translateY(-2px); box-shadow:0 12px 30px rgba(0,242,254,0.4); }

    .validation-summary-errors, .text-danger, .field-validation-error { color:#ef4444 !important; font-size:0.83rem; }
    .validation-summary-errors { padding:12px 16px; border-radius:10px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); }
    .validation-summary-errors ul, .validation-summary-valid ul { margin:0; padding-left:20px; }
    .field-error { display:block; margin-top:6px; min-height:18px; font-size:0.8rem; }

    .auth-footer-note { margin-top:20px; color:#64748b; font-size:0.875rem; text-align:center; }
    .auth-footer-note a { color:#00f2fe; text-decoration:none; font-weight:600; }
    .auth-footer-note a:hover { text-decoration:underline; }

    .ss-footer { background:#050818; border-top:1px solid rgba(0,242,254,0.1); padding:30px; text-align:center; color:#64748b; font-size:0.9rem; font-family:'Inter','Segoe UI',sans-serif; }
    .ss-footer-brand { color:#00f2fe; font-weight:700; }

    @@media (max-width:768px) {
        .auth-card { padding:32px 24px; border-radius:20px; }
        .auth-title { font-size:1.4rem; }
        .ss-navbar { padding:14px 20px; }
        .ss-nav-menu { display:none; }
    }
</style>

<nav class="ss-navbar">
    <div class="ss-navbar-inner">
        <a href="/" class="ss-logo">⚔️ Secure<span class="ss-logo-accent">Shop</span></a>
        <ul class="ss-nav-menu">
            <li><a href="/">Home</a></li>
            <li><a href="/shop">Shop</a></li>
            <li><a href="/generator">🔐 Generator</a></li>
        </ul>
        <div class="ss-nav-right">
            <a href="/cart" class="ss-nav-cart">🛒 <span class="ss-cart-count" id="ss-cart-count">0</span></a>
        </div>
    </div>
</nav>

<div class="ss-auth-page">
@{
    var usernameAttempt = ViewData.ModelState["RegisterUserForm.UserName"]?.AttemptedValue ?? "";
    var emailAttempt    = ViewData.ModelState["RegisterUserForm.Email"]?.AttemptedValue ?? "";
    var usernameError        = ViewData.ModelState["RegisterUserForm.UserName"]?.Errors.FirstOrDefault()?.ErrorMessage ?? "";
    var emailError           = ViewData.ModelState["RegisterUserForm.Email"]?.Errors.FirstOrDefault()?.ErrorMessage ?? "";
    var passwordError        = ViewData.ModelState["RegisterUserForm.Password"]?.Errors.FirstOrDefault()?.ErrorMessage ?? "";
    var confirmPasswordError = ViewData.ModelState["RegisterUserForm.ConfirmPassword"]?.Errors.FirstOrDefault()?.ErrorMessage ?? "";
}
<div class="auth-card">
    
    <h1 class="auth-title">Create account</h1>
    <p class="auth-subtitle">Join millions of protected users</p>
    <form method="post" class="form-horizontal no-multisubmit" action="/Register">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="text-danger"></div>
        <div class="mb-3">
            <label class="form-label" for="RegisterUserForm_UserName">Username</label>
            <input class="form-control" autofocus type="text"
                   id="RegisterUserForm_UserName" name="RegisterUserForm.UserName"
                   value="@usernameAttempt" placeholder="Enter username" />
            <span class="text-danger field-error">@usernameError</span>
        </div>
        <div class="mb-3">
            <label class="form-label" for="RegisterUserForm_Email">Email address</label>
            <input class="form-control" type="text"
                   id="RegisterUserForm_Email" name="RegisterUserForm.Email"
                   value="@emailAttempt" placeholder="Enter email" />
            <span class="text-danger field-error">@emailError</span>
        </div>
        <div class="mb-3">
            <label class="form-label" for="RegisterUserForm_Password">Password</label>
            <input class="form-control" autocomplete="new-password" type="password"
                   id="RegisterUserForm_Password" name="RegisterUserForm.Password"
                   placeholder="Enter password" />
            <span class="text-danger field-error">@passwordError</span>
        </div>
        <div class="mb-3">
            <label class="form-label" for="RegisterUserForm_ConfirmPassword">Confirm password</label>
            <input class="form-control" autocomplete="new-password" type="password"
                   id="RegisterUserForm_ConfirmPassword" name="RegisterUserForm.ConfirmPassword"
                   placeholder="Repeat password" />
            <span class="text-danger field-error">@confirmPasswordError</span>
        </div>
        <div class="mb-3">
            <button type="submit" class="btn btn-primary">🚀 Create account</button>
        </div>
    </form>
    <div class="auth-footer-note">Already have an account? <a href="/Login">Sign in →</a></div>
</div>
</div>

<footer class="ss-footer">
    <p>© 2026 <span class="ss-footer-brand">SecureShop</span> — Your Digital Life, Fully Protected 🛡️</p>
</footer>

<script>
(function() {
    try {
        var cart = JSON.parse(localStorage.getItem('secureshop_cart') || '[]');
        var total = cart.reduce(function(s,i){ return s+(i.quantity||1); }, 0);
        var el = document.getElementById('ss-cart-count');
        if (el) el.textContent = total;
    } catch(e) {}
})();
</script>
